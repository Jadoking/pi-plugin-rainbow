{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "pi-plugin-rainbow",
  "version": "0.1.0",
  "description": "Best-effort Pi Coding Agent port of oc-plugin-rainbow.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jadoking/pi-plugin-rainbow.git"
  },
  "homepage": "https://github.com/Jadoking/pi-plugin-rainbow#readme",
  "bugs": {
    "url": "https://github.com/Jadoking/pi-plugin-rainbow/issues"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "rainbow",
    "terminal-ui"
  ],
  "files": [
    "extensions",
    "README.md",
    "package.json",
    "tsconfig.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/rainbow/index.ts"
    ]
